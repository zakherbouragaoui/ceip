# CEIP Environment Variables
# Copy this file to .env and fill in the values

# ═══════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════
# Local development: uses SQLite (no config needed)
# Production (Render): set DATABASE_URL to PostgreSQL connection string
# DATABASE_URL=postgresql://user:pass@host:5432/ceip
DB_PATH=data/ceip.db

# ═══════════════════════════════════════════════
# LLM BACKEND
# ═══════════════════════════════════════════════
# ollama = local development (requires Ollama running)
# groq   = cloud deployment (requires GROQ_API_KEY)
LLM_BACKEND=ollama
OLLAMA_BASE=http://localhost:11434
GROQ_API_KEY=

# ═══════════════════════════════════════════════
# EMBEDDING BACKEND
# ═══════════════════════════════════════════════
# ollama      = local development (requires Ollama + nomic-embed-text)
# huggingface = cloud deployment (requires HF_TOKEN)
EMBEDDING_BACKEND=ollama
HF_TOKEN=

# ═══════════════════════════════════════════════
# VECTOR DATABASE
# ═══════════════════════════════════════════════
CHROMA_PATH=data/embeddings/

# ═══════════════════════════════════════════════
# AUTH (JWT)
# ═══════════════════════════════════════════════
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ═══════════════════════════════════════════════
# CORS (comma-separated origins, or * for all)
# ═══════════════════════════════════════════════
# Production: set to your Vercel URL
# CORS_ORIGINS=https://ceip.vercel.app
CORS_ORIGINS=*

# ═══════════════════════════════════════════════
# EXTERNAL APIs (for data ingestion)
# ═══════════════════════════════════════════════
CORE_API_KEY=
OPENALEX_EMAIL=
S2_API_KEY=
CROSSREF_EMAIL=
IUCN_API_KEY=
GBIF_USER=
GBIF_PASSWORD=

# ═══════════════════════════════════════════════
# EMAIL ALERTS (optional)
# ═══════════════════════════════════════════════
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ═══════════════════════════════════════════════
# DATA PATHS
# ═══════════════════════════════════════════════
CE_CSV_PATH=data/raw/conservation_evidence.csv
